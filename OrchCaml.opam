opam-version: "2.0"
synopsis: "A typed LLM orchestration framework for OCaml"
description:
  "OrchCaml provides a functional, type-safe interface for composing LLM pipelines with typed message passing, pluggable providers (Ollama, OpenAI-compatible), output parsers, prompt templates, conversation memory, and an interactive TUI."
maintainer: ["OrchCaml Contributors"]
authors: ["OrchCaml Contributors"]
license: "GPL-3.0"
tags: ["llm" "orchestration" "ai" "langchain" "ollama" "openai"]
homepage: "https://github.com/adukhan99/OrchCaml"
bug-reports: "https://github.com/adukhan99/OrchCaml/issues"
depends: [
  "ocaml"
  "dune" {>= "3.21" & >= "3.21"}
  "lwt" {>= "6.0"}
  "lwt_ppx" {>= "2.0"}
  "cohttp-lwt-unix" {>= "6.0"}
  "uri" {>= "4.0"}
  "yojson" {>= "3.0"}
  "cmdliner" {>= "1.3"}
  "fmt" {>= "0.9"}
  "re" {>= "1.10"}
  "otoml" {>= "1.0"}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/adukhan99/OrchCaml.git"
x-maintenance-intent: ["(latest)"]
